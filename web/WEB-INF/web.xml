<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ADD -->
    <servlet>
        <servlet-name>AddServlet</servlet-name>
        <servlet-class>servlet.AddServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddServlet</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>

    <!-- DISPLAY -->
    <servlet>
        <servlet-name>DisplayServlet</servlet-name>
        <servlet-class>servlet.DisplayServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DisplayServlet</servlet-name>
        <url-pattern>/display</url-pattern>
    </servlet-mapping>

    <!-- FILTER -->
    <servlet>
        <servlet-name>FilterServlet</servlet-name>
        <servlet-class>servlet.FilterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>FilterServlet</servlet-name>
        <url-pattern>/filter</url-pattern>
    </servlet-mapping>

    <!-- SORT -->
    <servlet>
        <servlet-name>SortServlet</servlet-name>
        <servlet-class>servlet.SortServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SortServlet</servlet-name>
        <url-pattern>/sort</url-pattern>
    </servlet-mapping>

    <servlet>
    	<servlet-name>TestDBServlet</servlet-name>
    	<servlet-class>servlet.TestDBServlet</servlet-class>
    </servlet>

    <servlet-mapping>
    	<servlet-name>TestDBServlet</servlet-name>
    	<url-pattern>/testdb</url-pattern>
    </servlet-mapping>

</web-app>